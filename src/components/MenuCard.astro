---
const {title, description, price} = Astro.props;

---

<div class="flex flex-col rounded-lg md:flex-row shadow-2xl/20 shadow-[5px_5px_10px_rgba(0,0,0,0.04)] text-shadow-black justify-between items-center gap-4 p-8 py-6 bg-[#F9F7F5] w-full sm:w-md">
    <div class="text-left">
        <h2 class="text-lg font-semibold text-[#434242]">{title}</h2>
        <p class="text-[#848484] text-sm">{description}</p>
    </div>
    <div class="text-right">
        <p class="text-[#f5a568] font-bold">S/ {price}</p>
    </div>
</div>