---
import { MapPin, Phone, Mail, Clock } from 'lucide-astro';
---

<div id="map" class="h-auto pb-20 w-full flex flex-col text-center items-center bg-[#F9F7F5]">
    <h1 id="menu" class="text-4xl md:text-6xl font-arial p-8 md:p-12 text-[#434242]">Visítanos</h1>
    <div class="w-3/5 md:w-2/5 mx-auto">
        <div class="border-2 border-[#d59b6f] w-full"></div>
    </div>

    <div class="mt-8 p-6 px-6 md:px-16 lg:px-52 gap-8 md:gap-16 flex flex-col md:flex-row justify-center gap-12 w-full"> 
        <div class="flex flex-col gap-6 h-auto w-full md:w-auto">
            <div class="flex flex-col gap-6 text-left">
                <div class="flex items-center gap-4">
                    <MapPin class="w-6 h-6 text-[#d59b6f] shrink-0" />
                    <p>Mz. 123, Calle Principal, Ciudad Ejemplo</p>
                </div>
                <div class="flex items-center gap-4">
                    <Phone class="w-6 h-6 text-[#d59b6f] shrink-0" />
                    <p>+51 937 638 689</p>
                </div>
                <div class="flex items-center gap-4">
                    <Mail class="w-6 h-6 text-[#d59b6f] shrink-0" />
                    <p>contact@maisoncafe.com</p>
                </div>
                <div class="flex items-center gap-4">
                    <Clock class="w-6 h-6 text-[#d59b6f] shrink-0" />
                    <p>Lunes a Viernes: 8:00 AM - 8:00 PM</p>
                </div>
            </div>
            <div>
                <iframe class="rounded w-full md:w-[400px]" src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d3683.5831559810445!2d-77.07796750303467!3d-12.000761379866024!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2spe!4v1771868563004!5m2!1sen!2spe" height="350" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
                </iframe>
            </div>
        </div>

        <div class="w-96 md:w-1/2 h-auto">
            <form class="flex flex-col gap-4">
                <h1 class="text-3xl font-light text-[#434242]">Tu Mensaje</h1>
                <input type="text" placeholder="Nombre" class="w-full mb-4 p-2 border border-gray-300 rounded">
                <input type="email" placeholder="Correo Electrónico" class="w-full mb-4 p-2 border border-gray-300 rounded">
                <textarea placeholder="Mensaje" class="w-full mb-4 p-2 border border-gray-300 rounded"></textarea>
                <button type="submit" class="bg-[#d59b6f] text-white px-4 py-2 cursor-pointer">Enviar</button>
            </form>
        </div>
    </div>
</div>